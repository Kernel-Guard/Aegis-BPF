{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aegisbpf/aegisbpf/blob/main/config/event-schema.json",
  "title": "AegisBPF Event Schema",
  "description": "JSON Schema for AegisBPF security events",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/ExecEvent" },
    { "$ref": "#/$defs/ExecArgvEvent" },
    { "$ref": "#/$defs/BlockEvent" },
    { "$ref": "#/$defs/NetBlockEvent" },
    { "$ref": "#/$defs/StateChangeEvent" },
    { "$ref": "#/$defs/ControlChangeEvent" },
    { "$ref": "#/$defs/DiagEvent" },
    { "$ref": "#/$defs/ForensicBlockEvent" }
  ],
  "$defs": {
    "ExecEvent": {
      "type": "object",
      "description": "Execution event - emitted when a process execution is observed",
      "required": ["type", "pid", "ppid", "start_time", "cgid", "cgroup_path", "comm"],
      "properties": {
        "type": {
          "type": "string",
          "const": "exec",
          "description": "Event type identifier"
        },
        "pid": {
          "type": "integer",
          "minimum": 0,
          "description": "Process ID of the executed process"
        },
        "ppid": {
          "type": "integer",
          "minimum": 0,
          "description": "Parent process ID"
        },
        "start_time": {
          "type": "integer",
          "minimum": 0,
          "description": "Process start time in kernel ticks or nanoseconds"
        },
        "exec_id": {
          "type": "string",
          "description": "Stable execution identifier (pid:start_time)"
        },
        "trace_id": {
          "type": "string",
          "description": "Correlation identifier for cross-signal tracing (matches exec_id)"
        },
        "cgid": {
          "type": "integer",
          "minimum": 0,
          "description": "Cgroup ID (inode number of cgroup directory)"
        },
        "cgroup_path": {
          "type": "string",
          "description": "Full path of the cgroup"
        },
        "comm": {
          "type": "string",
          "maxLength": 16,
          "description": "Command name (truncated to 16 characters)"
        }
      },
      "additionalProperties": false
    },
    "ExecArgvEvent": {
      "type": "object",
      "description": "Full argv capture event - emitted immediately after exec event with complete argument list",
      "required": ["type", "pid", "start_time", "argc", "argv"],
      "properties": {
        "type": {
          "type": "string",
          "const": "exec_argv",
          "description": "Event type identifier"
        },
        "pid": {
          "type": "integer",
          "minimum": 0,
          "description": "Process ID (matches preceding exec event)"
        },
        "start_time": {
          "type": "integer",
          "minimum": 0,
          "description": "Process start time (matches preceding exec event)"
        },
        "argc": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of captured arguments"
        },
        "argv": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Captured command-line arguments (may be truncated)"
        }
      },
      "additionalProperties": false
    },
    "DiagEvent": {
      "type": "object",
      "description": "Diagnostic event from the diagnostics ring buffer for debug/operational monitoring",
      "required": ["type", "diag_type", "timestamp"],
      "properties": {
        "type": {
          "type": "string",
          "const": "diag",
          "description": "Event type identifier"
        },
        "diag_type": {
          "type": "integer",
          "minimum": 1,
          "description": "Diagnostic event type (1=map_pressure, 2=hook_error, 3=process_eviction)"
        },
        "timestamp": {
          "type": "integer",
          "minimum": 0,
          "description": "Boot-time nanosecond timestamp"
        },
        "data1": {
          "type": "integer",
          "description": "Type-specific data field 1"
        },
        "data2": {
          "type": "integer",
          "description": "Type-specific data field 2"
        },
        "msg": {
          "type": "string",
          "maxLength": 64,
          "description": "Optional diagnostic message"
        }
      },
      "additionalProperties": false
    },
    "BlockEvent": {
      "type": "object",
      "description": "Block or audit event emitted on denied file open attempts",
      "required": [
        "type",
        "pid",
        "ppid",
        "start_time",
        "parent_start_time",
        "cgid",
        "cgroup_path",
        "ino",
        "dev",
        "action",
        "comm"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "block",
          "description": "Event type identifier"
        },
        "pid": {
          "type": "integer",
          "minimum": 0,
          "description": "Process ID that attempted the access"
        },
        "ppid": {
          "type": "integer",
          "minimum": 0,
          "description": "Parent process ID"
        },
        "start_time": {
          "type": "integer",
          "minimum": 0,
          "description": "Process start time"
        },
        "exec_id": {
          "type": "string",
          "description": "Stable execution identifier (pid:start_time)"
        },
        "trace_id": {
          "type": "string",
          "description": "Correlation identifier for cross-signal tracing (matches exec_id)"
        },
        "parent_start_time": {
          "type": "integer",
          "minimum": 0,
          "description": "Parent process start time"
        },
        "parent_exec_id": {
          "type": "string",
          "description": "Stable parent execution identifier (ppid:parent_start_time)"
        },
        "parent_trace_id": {
          "type": "string",
          "description": "Parent correlation identifier (matches parent_exec_id)"
        },
        "cgid": {
          "type": "integer",
          "minimum": 0,
          "description": "Cgroup ID (inode number of cgroup directory)"
        },
        "cgroup_path": {
          "type": "string",
          "description": "Full path of the cgroup"
        },
        "ino": {
          "type": "integer",
          "minimum": 0,
          "description": "Inode number of the file"
        },
        "dev": {
          "type": "integer",
          "minimum": 0,
          "description": "Device number of the file"
        },
        "path": {
          "type": "string",
          "description": "Path of the file when available"
        },
        "resolved_path": {
          "type": "string",
          "description": "Resolved canonical path (if different from path)"
        },
        "action": {
          "type": "string",
          "enum": ["AUDIT", "INT", "TERM", "KILL", "BLOCK"],
          "description": "Action taken (AUDIT in audit mode, enforce action in enforce mode)"
        },
        "comm": {
          "type": "string",
          "maxLength": 16,
          "description": "Command name (truncated to 16 characters)"
        }
      },
      "additionalProperties": false
    },
    "NetBlockEvent": {
      "type": "object",
      "description": "Network block or audit event emitted on denied connect, bind, listen, accept, or sendmsg attempts",
      "required": [
        "type",
        "pid",
        "ppid",
        "start_time",
        "parent_start_time",
        "cgid",
        "cgroup_path",
        "family",
        "protocol",
        "direction",
        "action",
        "rule_type",
        "comm"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["net_connect_block", "net_bind_block", "net_listen_block", "net_accept_block", "net_sendmsg_block"],
          "description": "Event type identifier"
        },
        "pid": {
          "type": "integer",
          "minimum": 0,
          "description": "Process ID that attempted the network operation"
        },
        "ppid": {
          "type": "integer",
          "minimum": 0,
          "description": "Parent process ID"
        },
        "start_time": {
          "type": "integer",
          "minimum": 0,
          "description": "Process start time"
        },
        "exec_id": {
          "type": "string",
          "description": "Stable execution identifier (pid:start_time)"
        },
        "trace_id": {
          "type": "string",
          "description": "Correlation identifier for cross-signal tracing"
        },
        "parent_start_time": {
          "type": "integer",
          "minimum": 0,
          "description": "Parent process start time"
        },
        "parent_exec_id": {
          "type": "string",
          "description": "Stable parent execution identifier (ppid:parent_start_time)"
        },
        "parent_trace_id": {
          "type": "string",
          "description": "Parent correlation identifier (matches parent_exec_id)"
        },
        "cgid": {
          "type": "integer",
          "minimum": 0,
          "description": "Cgroup ID (inode number of cgroup directory)"
        },
        "cgroup_path": {
          "type": "string",
          "description": "Full path of the cgroup"
        },
        "family": {
          "type": "string",
          "enum": ["ipv4", "ipv6"],
          "description": "Address family"
        },
        "protocol": {
          "type": "string",
          "pattern": "^(tcp|udp|[0-9]+)$",
          "description": "IP protocol name or numeric value"
        },
        "direction": {
          "type": "string",
          "enum": ["egress", "bind", "listen", "accept", "send"],
          "description": "Network direction"
        },
        "remote_ip": {
          "type": "string",
          "description": "Remote IP address (for connect/accept/send events)"
        },
        "remote_port": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535,
          "description": "Remote port (for connect/accept/send events)"
        },
        "local_port": {
          "type": "integer",
          "minimum": 0,
          "maximum": 65535,
          "description": "Local port (for bind/listen/accept/send events)"
        },
        "rule_type": {
          "type": "string",
          "enum": ["ip", "cidr", "port", "ip_port", "identity"],
          "description": "Type of deny rule that matched"
        },
        "action": {
          "type": "string",
          "enum": ["AUDIT", "INT", "TERM", "KILL", "BLOCK"],
          "description": "Action taken"
        },
        "comm": {
          "type": "string",
          "maxLength": 16,
          "description": "Command name (truncated to 16 characters)"
        }
      },
      "additionalProperties": false
    },
    "StateChangeEvent": {
      "type": "object",
      "description": "Runtime state transition event emitted when enforcement posture changes",
      "required": [
        "type",
        "event_version",
        "state",
        "reason_code",
        "strict_mode",
        "transition_id",
        "degradation_count"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "state_change",
          "description": "Event type identifier"
        },
        "event_version": {
          "type": "integer",
          "const": 1,
          "description": "Version of the state-change event schema"
        },
        "state": {
          "type": "string",
          "enum": ["ENFORCE", "AUDIT_FALLBACK", "DEGRADED"],
          "description": "Current runtime posture"
        },
        "reason_code": {
          "type": "string",
          "minLength": 1,
          "description": "Machine-readable reason for the transition"
        },
        "detail": {
          "type": "string",
          "description": "Optional human-readable transition detail"
        },
        "strict_mode": {
          "type": "boolean",
          "description": "Whether strict degrade mode is enabled"
        },
        "transition_id": {
          "type": "integer",
          "minimum": 1,
          "description": "Monotonic transition sequence number for this process"
        },
        "degradation_count": {
          "type": "integer",
          "minimum": 0,
          "description": "Count of transitions into fallback/degraded states"
        }
      },
      "additionalProperties": false
    },
    "ControlChangeEvent": {
      "type": "object",
      "description": "Control-plane event emitted when emergency controls are toggled",
      "required": [
        "type",
        "event_version",
        "control",
        "action",
        "enabled",
        "prev_enabled",
        "changed_at_unix",
        "uid",
        "pid",
        "node_name",
        "reason",
        "reason_sha256",
        "storm_active",
        "storm_transitions_in_window",
        "storm_threshold",
        "storm_window_seconds"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "control_change",
          "description": "Event type identifier"
        },
        "event_version": {
          "type": "integer",
          "const": 1,
          "description": "Version of the control-change event schema"
        },
        "control": {
          "type": "string",
          "enum": ["emergency_disable"],
          "description": "Control surface that changed"
        },
        "action": {
          "type": "string",
          "enum": ["disable", "enable"],
          "description": "Control action performed"
        },
        "enabled": {
          "type": "boolean",
          "description": "Whether emergency disable is enabled after the action"
        },
        "prev_enabled": {
          "type": "boolean",
          "description": "Whether emergency disable was enabled before the action"
        },
        "changed_at_unix": {
          "type": "integer",
          "minimum": 0,
          "description": "Unix timestamp when the action was applied"
        },
        "uid": {
          "type": "integer",
          "minimum": 0,
          "description": "Unix UID of the caller"
        },
        "pid": {
          "type": "integer",
          "minimum": 0,
          "description": "Process ID of the caller"
        },
        "node_name": {
          "type": "string",
          "minLength": 1,
          "description": "Kubernetes node name or host name"
        },
        "reason": {
          "type": "string",
          "description": "Sanitized human-readable reason (single-line, length-capped)"
        },
        "reason_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$",
          "description": "SHA256 of the raw reason bytes before sanitization/truncation"
        },
        "policy_hash": {
          "type": "string",
          "description": "Best-effort applied policy hash snapshot (when available)"
        },
        "storm_active": {
          "type": "boolean",
          "description": "Whether a toggle storm was active at the time of this action"
        },
        "storm_transitions_in_window": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of transitions observed in the storm window"
        },
        "storm_threshold": {
          "type": "integer",
          "minimum": 0,
          "description": "Configured transition threshold for storm activation"
        },
        "storm_window_seconds": {
          "type": "integer",
          "minimum": 0,
          "description": "Configured window size for storm detection"
        }
      },
      "additionalProperties": false
    },
    "ForensicBlockEvent": {
      "type": "object",
      "description": "Forensic block event - enriched block event with UID/GID and exec identity context, emitted via priority ring buffer",
      "required": [
        "type",
        "pid",
        "ppid",
        "start_time",
        "parent_start_time",
        "cgid",
        "cgroup_path",
        "ino",
        "dev",
        "uid",
        "gid",
        "action",
        "comm"
      ],
      "properties": {
        "type": {
          "type": "string",
          "const": "forensic_block",
          "description": "Event type identifier"
        },
        "pid": {
          "type": "integer",
          "minimum": 0,
          "description": "Process ID that attempted the access"
        },
        "ppid": {
          "type": "integer",
          "minimum": 0,
          "description": "Parent process ID"
        },
        "start_time": {
          "type": "integer",
          "minimum": 0,
          "description": "Process start time"
        },
        "exec_id": {
          "type": "string",
          "description": "Stable execution identifier (pid:start_time)"
        },
        "trace_id": {
          "type": "string",
          "description": "Correlation identifier for cross-signal tracing"
        },
        "parent_start_time": {
          "type": "integer",
          "minimum": 0,
          "description": "Parent process start time"
        },
        "parent_exec_id": {
          "type": "string",
          "description": "Stable parent execution identifier (ppid:parent_start_time)"
        },
        "parent_trace_id": {
          "type": "string",
          "description": "Parent correlation identifier"
        },
        "cgid": {
          "type": "integer",
          "minimum": 0,
          "description": "Cgroup ID"
        },
        "cgroup_path": {
          "type": "string",
          "description": "Full path of the cgroup"
        },
        "ino": {
          "type": "integer",
          "minimum": 0,
          "description": "Inode number of the blocked file"
        },
        "dev": {
          "type": "integer",
          "minimum": 0,
          "description": "Device number of the blocked file"
        },
        "uid": {
          "type": "integer",
          "minimum": 0,
          "description": "User ID of the process"
        },
        "gid": {
          "type": "integer",
          "minimum": 0,
          "description": "Group ID of the process"
        },
        "exec_ino": {
          "type": "integer",
          "minimum": 0,
          "description": "Inode of the binary that triggered the block"
        },
        "exec_dev": {
          "type": "integer",
          "minimum": 0,
          "description": "Device of the binary that triggered the block"
        },
        "exec_stage": {
          "type": "integer",
          "minimum": 0,
          "description": "Exec identity verification stage"
        },
        "verified_exec": {
          "type": "boolean",
          "description": "Whether the binary is exec-identity verified"
        },
        "exec_identity_known": {
          "type": "boolean",
          "description": "Whether exec identity was available"
        },
        "action": {
          "type": "string",
          "enum": ["AUDIT", "INT", "TERM", "KILL", "BLOCK"],
          "description": "Action taken"
        },
        "comm": {
          "type": "string",
          "maxLength": 16,
          "description": "Command name (truncated to 16 characters)"
        }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "type": "exec",
      "pid": 12345,
      "ppid": 1000,
      "start_time": 123456789,
      "exec_id": "12345:123456789",
      "trace_id": "12345:123456789",
      "cgid": 5678,
      "cgroup_path": "/sys/fs/cgroup/user.slice/user-1000.slice",
      "comm": "bash"
    },
    {
      "type": "exec_argv",
      "pid": 12345,
      "start_time": 123456789,
      "argc": 3,
      "argv": ["/usr/bin/curl", "-s", "https://example.com"]
    },
    {
      "type": "block",
      "pid": 12346,
      "ppid": 12345,
      "start_time": 223456789,
      "exec_id": "12346:223456789",
      "trace_id": "12346:223456789",
      "parent_start_time": 123456789,
      "parent_exec_id": "12345:123456789",
      "parent_trace_id": "12345:123456789",
      "cgid": 5678,
      "cgroup_path": "/sys/fs/cgroup/user.slice/user-1000.slice",
      "ino": 123456,
      "dev": 259,
      "path": "/etc/shadow",
      "resolved_path": "/etc/shadow",
      "action": "KILL",
      "comm": "cat"
    },
    {
      "type": "net_connect_block",
      "pid": 12347,
      "ppid": 12345,
      "start_time": 323456789,
      "exec_id": "12347:323456789",
      "trace_id": "12347:323456789",
      "parent_start_time": 123456789,
      "parent_exec_id": "12345:123456789",
      "parent_trace_id": "12345:123456789",
      "cgid": 5678,
      "cgroup_path": "/sys/fs/cgroup/user.slice/user-1000.slice",
      "family": "ipv4",
      "protocol": "tcp",
      "direction": "egress",
      "remote_ip": "10.0.0.1",
      "remote_port": 443,
      "rule_type": "ip_port",
      "action": "TERM",
      "comm": "curl"
    },
    {
      "type": "net_listen_block",
      "pid": 12348,
      "ppid": 12345,
      "start_time": 423456789,
      "exec_id": "12348:423456789",
      "trace_id": "12348:423456789",
      "parent_start_time": 123456789,
      "parent_exec_id": "12345:123456789",
      "parent_trace_id": "12345:123456789",
      "cgid": 5678,
      "cgroup_path": "/sys/fs/cgroup/user.slice/user-1000.slice",
      "family": "ipv4",
      "protocol": "tcp",
      "direction": "listen",
      "local_port": 8080,
      "rule_type": "port",
      "action": "BLOCK",
      "comm": "python"
    },
    {
      "type": "net_accept_block",
      "pid": 12349,
      "ppid": 12345,
      "start_time": 523456789,
      "exec_id": "12349:523456789",
      "trace_id": "12349:523456789",
      "parent_start_time": 123456789,
      "parent_exec_id": "12345:123456789",
      "parent_trace_id": "12345:123456789",
      "cgid": 5678,
      "cgroup_path": "/sys/fs/cgroup/user.slice/user-1000.slice",
      "family": "ipv4",
      "protocol": "tcp",
      "direction": "accept",
      "remote_ip": "10.0.0.2",
      "remote_port": 51514,
      "local_port": 8080,
      "rule_type": "port",
      "action": "TERM",
      "comm": "nginx"
    },
    {
      "type": "net_sendmsg_block",
      "pid": 12350,
      "ppid": 12345,
      "start_time": 623456789,
      "exec_id": "12350:623456789",
      "trace_id": "12350:623456789",
      "parent_start_time": 123456789,
      "parent_exec_id": "12345:123456789",
      "parent_trace_id": "12345:123456789",
      "cgid": 5678,
      "cgroup_path": "/sys/fs/cgroup/user.slice/user-1000.slice",
      "family": "ipv4",
      "protocol": "udp",
      "direction": "send",
      "remote_ip": "10.0.0.3",
      "remote_port": 53,
      "local_port": 40000,
      "rule_type": "cidr",
      "action": "BLOCK",
      "comm": "dns-client"
    },
    {
      "type": "state_change",
      "event_version": 1,
      "state": "AUDIT_FALLBACK",
      "reason_code": "CAPABILITY_AUDIT_ONLY",
      "detail": "kernel lacks required enforce hooks",
      "strict_mode": false,
      "transition_id": 2,
      "degradation_count": 1
    },
    {
      "type": "control_change",
      "event_version": 1,
      "control": "emergency_disable",
      "action": "disable",
      "enabled": true,
      "prev_enabled": false,
      "changed_at_unix": 1704672000,
      "uid": 0,
      "pid": 1234,
      "node_name": "node-1",
      "reason": "TICKET=INC-1234 mitigation",
      "reason_sha256": "0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef",
      "storm_active": false,
      "storm_transitions_in_window": 1,
      "storm_threshold": 10,
      "storm_window_seconds": 60
    },
    {
      "type": "forensic_block",
      "pid": 12351,
      "ppid": 12345,
      "start_time": 723456789,
      "exec_id": "12351:723456789",
      "trace_id": "12351:723456789",
      "parent_start_time": 123456789,
      "parent_exec_id": "12345:123456789",
      "parent_trace_id": "12345:123456789",
      "cgid": 5678,
      "cgroup_path": "/sys/fs/cgroup/user.slice/user-1000.slice",
      "ino": 654321,
      "dev": 259,
      "uid": 1000,
      "gid": 1000,
      "exec_ino": 111222,
      "exec_dev": 259,
      "exec_stage": 2,
      "verified_exec": false,
      "exec_identity_known": true,
      "action": "KILL",
      "comm": "malware"
    }
  ]
}
