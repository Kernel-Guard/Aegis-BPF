{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for AegisBPF metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "AegisBPF Executive Overview — high-level security posture and blocking activity",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Blocks (All Hooks)",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(aegisbpf_blocks_total)",
          "legendFormat": "blocks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 100, "color": "yellow" },
              { "value": 1000, "color": "red" }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Network Blocks",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(aegisbpf_net_blocks_total)",
          "legendFormat": "net_blocks"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 500, "color": "red" }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Ring Buffer Drops",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(aegisbpf_ringbuf_drops_total) + sum(aegisbpf_net_ringbuf_drops_total)",
          "legendFormat": "drops"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 1, "color": "orange" },
              { "value": 100, "color": "red" }
            ]
          },
          "unit": "short"
        }
      }
    },
    {
      "title": "Runtime State",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "aegisbpf_runtime_state{state=\"ENFORCE\"} == 1",
          "legendFormat": "ENFORCE"
        },
        {
          "expr": "aegisbpf_runtime_state{state=\"AUDIT_FALLBACK\"} == 1",
          "legendFormat": "AUDIT"
        },
        {
          "expr": "aegisbpf_runtime_state{state=\"DEGRADED\"} == 1",
          "legendFormat": "DEGRADED"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ENFORCE", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "—" } } }
          ]
        }
      }
    },
    {
      "title": "Block Rate (per minute)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(aegisbpf_blocks_total[5m]) * 60",
          "legendFormat": "file blocks/min"
        },
        {
          "expr": "sum(rate(aegisbpf_net_blocks_total[5m])) * 60",
          "legendFormat": "net blocks/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "opm"
        }
      }
    },
    {
      "title": "Network Blocks by Type",
      "type": "piechart",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "aegisbpf_net_blocks_total",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "title": "Map Utilization",
      "type": "bargauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 4 },
      "targets": [
        {
          "expr": "aegisbpf_map_utilization",
          "legendFormat": "{{map}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.8, "color": "yellow" },
              { "value": 0.95, "color": "red" }
            ]
          },
          "max": 1,
          "unit": "percentunit"
        }
      }
    },
    {
      "title": "Hooks Attached",
      "type": "table",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "aegisbpf_hook_attached",
          "legendFormat": "{{hook}}",
          "format": "table",
          "instant": true
        }
      ]
    },
    {
      "title": "Enforce Capable",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "aegisbpf_enforce_capable",
          "legendFormat": "enforce_capable"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "YES", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "NO", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "Emergency Toggle Storm",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 12 },
      "targets": [
        {
          "expr": "aegisbpf_emergency_toggle_storm_active",
          "legendFormat": "storm_active"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "NORMAL", "color": "green" } } },
            { "type": "value", "options": { "1": { "text": "STORM", "color": "red" } } }
          ]
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["aegisbpf", "security", "ebpf"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "AegisBPF — Executive Overview",
  "uid": "aegisbpf-executive",
  "version": 1
}
