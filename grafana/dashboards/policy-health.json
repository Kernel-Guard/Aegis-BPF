{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for AegisBPF metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "description": "AegisBPF Policy Health — rule coverage, policy drift, and configuration status",
  "editable": true,
  "panels": [
    {
      "title": "Active Deny Rules",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "aegisbpf_deny_inode_entries + aegisbpf_deny_path_entries",
          "legendFormat": "file rules"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Active Network Rules",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "sum(aegisbpf_net_rules_total)",
          "legendFormat": "net rules"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Allow Cgroup Entries",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "aegisbpf_allow_cgroup_entries",
          "legendFormat": "cgroups"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Exec Identity Allowlist",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "aegisbpf_allow_exec_inode_entries",
          "legendFormat": "exec entries"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Map Utilization (Critical Maps)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "aegisbpf_map_utilization{map=~\"deny_inode|deny_path|allow_cgroup|allow_exec_inode\"}",
          "legendFormat": "{{map}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.8, "color": "yellow" },
              { "value": 0.95, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Map Capacity vs Usage",
      "type": "bargauge",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "aegisbpf_deny_inode_entries / aegisbpf_map_capacity{map=\"deny_inode\"}",
          "legendFormat": "deny_inode"
        },
        {
          "expr": "aegisbpf_deny_path_entries / aegisbpf_map_capacity{map=\"deny_path\"}",
          "legendFormat": "deny_path"
        },
        {
          "expr": "aegisbpf_allow_cgroup_entries / aegisbpf_map_capacity{map=\"allow_cgroup\"}",
          "legendFormat": "allow_cgroup"
        },
        {
          "expr": "aegisbpf_allow_exec_inode_entries / aegisbpf_map_capacity{map=\"allow_exec_inode\"}",
          "legendFormat": "allow_exec_inode"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "green" },
              { "value": 0.8, "color": "yellow" },
              { "value": 0.95, "color": "red" }
            ]
          }
        }
      }
    },
    {
      "title": "Network Rules by Type",
      "type": "piechart",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "aegisbpf_net_rules_total",
          "legendFormat": "{{type}}"
        }
      ]
    },
    {
      "title": "Network Map Utilization",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 12 },
      "targets": [
        {
          "expr": "aegisbpf_map_utilization{map=~\"deny_ipv4|deny_ipv6|deny_port|deny_ip_port_v4|deny_ip_port_v6|deny_cidr_v4|deny_cidr_v6\"}",
          "legendFormat": "{{map}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 10 },
          "unit": "percentunit",
          "max": 1
        }
      }
    },
    {
      "title": "Capability Report Status",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "aegisbpf_capability_report_present",
          "legendFormat": "report"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "PRESENT", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "MISSING", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "Capability Contract Valid",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 20 },
      "targets": [
        {
          "expr": "aegisbpf_capability_contract_valid",
          "legendFormat": "contract"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "VALID", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "INVALID", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "File Hooks Contract",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 20 },
      "targets": [
        {
          "expr": "aegisbpf_file_hooks_attached == aegisbpf_file_hooks_expected",
          "legendFormat": "contract"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "SATISFIED", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "MISMATCH", "color": "red" } } }
          ]
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["aegisbpf", "policy", "configuration"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "AegisBPF — Policy Health",
  "uid": "aegisbpf-policy",
  "version": 1
}
