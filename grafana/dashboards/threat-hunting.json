{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for AegisBPF metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "description": "AegisBPF Threat Hunting — anomaly detection and kernel security event investigation",
  "editable": true,
  "panels": [
    {
      "title": "Kernel Security Blocks",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "aegisbpf_hook_attached{hook=\"ptrace\"} == 1",
          "legendFormat": "ptrace hook"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ACTIVE", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "INACTIVE", "color": "dark-yellow" } } }
          ]
        }
      }
    },
    {
      "title": "Module Load Hook",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "aegisbpf_hook_attached{hook=\"module_load\"}",
          "legendFormat": "module_load"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ACTIVE", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "INACTIVE", "color": "dark-yellow" } } }
          ]
        }
      }
    },
    {
      "title": "BPF Tamper Protection",
      "type": "stat",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "aegisbpf_hook_attached{hook=\"bpf\"}",
          "legendFormat": "bpf"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "ACTIVE", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "INACTIVE", "color": "dark-yellow" } } }
          ]
        }
      }
    },
    {
      "title": "Block Rate Anomaly Detection",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "rate(aegisbpf_blocks_total[5m]) * 60",
          "legendFormat": "current block rate"
        },
        {
          "expr": "avg_over_time(rate(aegisbpf_blocks_total[5m])[1h:5m]) * 60",
          "legendFormat": "1h average"
        },
        {
          "expr": "(avg_over_time(rate(aegisbpf_blocks_total[5m])[1h:5m]) + 2 * stddev_over_time(rate(aegisbpf_blocks_total[5m])[1h:5m])) * 60",
          "legendFormat": "2σ upper bound"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 5,
            "lineInterpolation": "smooth"
          },
          "unit": "opm"
        }
      }
    },
    {
      "title": "Network Block Activity Heatmap",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "rate(aegisbpf_net_blocks_total{type=\"connect\"}[5m]) * 60",
          "legendFormat": "connect"
        },
        {
          "expr": "rate(aegisbpf_net_blocks_total{type=\"bind\"}[5m]) * 60",
          "legendFormat": "bind"
        },
        {
          "expr": "rate(aegisbpf_net_blocks_total{type=\"listen\"}[5m]) * 60",
          "legendFormat": "listen"
        },
        {
          "expr": "rate(aegisbpf_net_blocks_total{type=\"accept\"}[5m]) * 60",
          "legendFormat": "accept"
        },
        {
          "expr": "rate(aegisbpf_net_blocks_total{type=\"send\"}[5m]) * 60",
          "legendFormat": "send"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "bars", "fillOpacity": 80, "stacking": { "mode": "normal" } },
          "unit": "opm"
        }
      }
    },
    {
      "title": "MITRE ATT&CK Coverage",
      "type": "table",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "aegisbpf_hook_attached",
          "legendFormat": "{{hook}}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "hook": "Hook",
              "Value": "Active"
            }
          }
        }
      ],
      "description": "Hook → MITRE mapping:\nptrace → T1055.008 (Ptrace Injection)\nmodule_load → T1547.006 (Kernel Module Persistence)\nbpf → T1562 (Impair Defenses)\nsocket_connect → T1071 (Application Layer Protocol)\nfile_open → T1005 (Data from Local System)"
    },
    {
      "title": "Emergency Control Transitions",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "aegisbpf_emergency_toggle_transitions_total",
          "legendFormat": "transitions"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line" },
          "unit": "short"
        }
      }
    },
    {
      "title": "Backpressure Drops (Security Event Loss)",
      "type": "timeseries",
      "datasource": "${DS_PROMETHEUS}",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "rate(aegisbpf_backpressure_priority_drops_total[5m])",
          "legendFormat": "priority drops/s (enforcement events lost)"
        },
        {
          "expr": "rate(aegisbpf_backpressure_telemetry_drops_total[5m])",
          "legendFormat": "telemetry drops/s (exec events lost)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "fillOpacity": 20 },
          "unit": "ops"
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["aegisbpf", "security", "threat-hunting", "mitre-attack"],
  "time": { "from": "now-24h", "to": "now" },
  "title": "AegisBPF — Threat Hunting",
  "uid": "aegisbpf-threats",
  "version": 1
}
